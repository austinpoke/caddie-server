# ─── Caddie Server Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# Port the server listens on (default 3001)
PORT=3001

# Allowed origins for CORS — comma-separated list of your web app URL(s)
# In development: http://localhost:5500,http://127.0.0.1:5500
# In production:  https://yourcaddieapp.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# GHIN API base URL (do not change unless USGA updates it)
GHIN_API_BASE=https://api.ghin.com/api/v1

# Optional: A server-level GHIN service account for read-only golfer lookups.
# If set, the server uses this token for search requests instead of per-user tokens.
# Leave blank to require users to log in with their own GHIN credentials.
# GHIN_SERVICE_EMAIL=
# GHIN_SERVICE_PASSWORD=

# Session secret — used to sign session cookies (change to a long random string)
SESSION_SECRET=change_me_to_a_long_random_string
